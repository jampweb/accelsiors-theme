{
  "version": 2,
  "settings": {
    "appearanceTools": true,
    "layout": {
      "contentSize": "1200px",
      "wideSize": "1400px"
    },
    "color": {
      "defaultPalette": false,
      "palette": [
        {
          "slug": "primary",
          "color": "#003366",
          "name": "Accelsiors Dark Blue"
        },
        {
          "slug": "secondary",
          "color": "#005599",
          "name": "Accelsiors Light Blue"
        },
        {
          "slug": "accent",
          "color": "#663399",
          "name": "HexaHelix Purple"
        },
        {
          "slug": "white",
          "color": "#ffffff",
          "name": "White"
        },
        {
          "slug": "light-gray",
          "color": "#f5f5f5",
          "name": "Light Gray"
        },
        {
          "slug": "text-main",
          "color": "#1a1a1a",
          "name": "Dark Text"
        }
      ]
    },
    "typography": {
      "fontFamilies": [
        {
          "fontFamily": "Inter, system-ui, -apple-system, sans-serif",
          "name": "Inter",
          "slug": "sans"
        }
      ],
      "fontSizes": [
        { "slug": "small", "size": "14px", "name": "Small" },
        { "slug": "medium", "size": "18px", "name": "Medium" },
        { "slug": "large", "size": "24px", "name": "Large" },
        { "slug": "xl", "size": "36px", "name": "XL" },
        { "slug": "xxl", "size": "48px", "name": "XXL" }
      ]
    }
  },
  "styles": {
    "blocks": {
      "core/button": {
        "color": {
          "background": "var(--wp--preset--color--primary)",
          "text": "var(--wp--preset--color--white)"
        },
        "border": {
          "radius": "4px"
        }
      }
    },
    "elements": {
      "link": {
        "color": { "text": "var(--wp--preset--color--secondary)" }
      }
    }
  }
}