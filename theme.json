{
  "version": 2,
  "settings": {
    "appearanceTools": true,
    "layout": {
      "contentSize": "80%",
      "wideSize": "100%"
    },
    "blocks": {
      "core/button": {
        "border": {
          "color": true,
          "style": true,
          "width": true
        }
      }
    },
    "color": {
      "defaultPalette": false,
      "palette": [
        {
          "slug": "primary",
          "color": "#003366",
          "name": "Accelsiors Dark Blue"
        },
        {
          "slug": "secondary",
          "color": "#005599",
          "name": "Accelsiors Light Blue"
        },
        {
          "slug": "accent",
          "color": "#663399",
          "name": "HexaHelix Purple"
        },
        {
          "slug": "white",
          "color": "#ffffff",
          "name": "White"
        },
        {
          "slug": "light-gray",
          "color": "#f5f5f5",
          "name": "Light Gray"
        },
        {
          "slug": "text-main",
          "color": "#1a1a1a",
          "name": "Dark Text"
        }
      ]
    },
    "typography": {
      "fontFamilies": [
        {
          "fontFamily": "system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, sans-serif",
          "name": "System UI",
          "slug": "sans"
        }
      ],
      "fontSizes": [
        { "slug": "small", "size": "14px", "name": "Small" },
        { "slug": "medium", "size": "18px", "name": "Medium" },
        { "slug": "large", "size": "24px", "name": "Large" },
        { "slug": "xl", "size": "36px", "name": "XL" },
        { "slug": "xxl", "size": "48px", "name": "XXL" }
      ]
    }
  },
  "styles": {
      "typography": {
          "fontFamily": "var(--wp--preset--font-family--sans)",
          "fontSize": "18px",
          "lineHeight": "1.6"
      },
      "blocks": {
          "core/button": {
              "color": {
                  "background": "#663399",
                  "text": "#ffffff"
              },
              "border": {
                  "radius": "0px"
              }
          },
          "core/image": {
              "border": {
                  "radius": "0px"
              }
          }
      },
      "elements": {
          "link": {
              "color": {
                  "text": "var(--wp--preset--color--accent)"
              },
    "typography": { "fontWeight": "700" }
  },
  "h1": { "typography": { "fontWeight": "700", "letterSpacing": "-0.02em" } },
  "h2": { "typography": { "fontWeight": "700", "letterSpacing": "-0.02em" } },
  "h3": { "typography": { "fontWeight": "700", "letterSpacing": "-0.02em" } }
}
}